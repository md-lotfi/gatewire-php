{
    "name": "gatewire/client",
    "description": "Official PHP SDK for the GateWire SMS Infrastructure.",
    "version": "1.0.2",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "GateWire Team",
            "email": "dev@gatewire.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
